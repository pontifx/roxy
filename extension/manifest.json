{
  "manifest_version": 3,
  "name": "Roxy",
  "version": "0.1.0",
  "description": "Turn your browser into a passive income machine. Share your session, earn from bug bounties and pricing data.",
  "permissions": [
    "proxy",
    "webRequest",
    "storage",
    "alarms",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
